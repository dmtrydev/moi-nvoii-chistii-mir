# Конфигурация ночной синхронизации с реестром Росприроднадзора.
# Скопируйте этот файл в parser/.env (на VDS) и заполните значения.

# Корневой URL API-сервера (без слэша на конце).
API_BASE_URL=https://your-domain.example

# Bearer-токен сервисной синхронизации. Должен совпадать с RPN_SYNC_TOKEN на сервере.
# Сгенерировать: openssl rand -hex 32
RPN_SYNC_TOKEN=

# Сколько ИНН за один прогон. Дефолт 10000. Для тестового запуска уменьшите до 50.
INNS_LIMIT=10000

# Свежесть snapshot, после которой ИНН попадает в очередь синка (дни). Дефолт 7.
STALE_DAYS=7

# Размер батча при отправке в /api/rpn-sync/upsert. Не больше 500.
BATCH_SIZE=500

# Пауза между батчами (мс), чтобы не упереться в общий rate-limit. Дефолт 700.
BATCH_DELAY_MS=700
