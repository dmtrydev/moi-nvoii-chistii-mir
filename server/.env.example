# Timeweb Cloud AI — Access ID агента (обязателен для анализа лицензий)
# Документация: https://agent.timeweb.cloud/docs
TIMEWEB_ACCESS_ID=adea83eb-75b9-41cb-95e0-6cb244587767
# Bearer-токен (JWT API key из личного кабинета Timeweb). Если не задан, в Authorization используется Access ID.
# TIMEWEB_BEARER_TOKEN=eyJ...
# При необходимости укажите значение для заголовка x-proxy-source (если требуется API)

# ArcGIS REST export ПКК6 (земельные участки и др.). По умолчанию — сервис Росреестра.
# CADASTRE_EXPORT_BASE=https://pkk.rosreestr.ru/arcgis/rest/services/PKK6/CadastreObjects/MapServer/export

# НСПД (ex-ПКК): базовый URL для WMS identify, geoportal search и intersects по bbox.
# По умолчанию https://nspd.gov.ru (pkk.rosreestr.ru отдаёт редирект/HTML, /api/features часто недоступен).
# CADASTRE_PKK_API_BASE=https://nspd.gov.ru
# Referer для запросов (как у карты НСПД). По умолчанию: {CADASTRE_PKK_API_BASE}/map?thematic=PKK
# CADASTRE_PKK_REFERER=https://nspd.gov.ru/map?thematic=PKK
# Опционально: ArcGIS MapServer для GeoJSON в /parcels; если не задан — используется intersects НСПД.
# CADASTRE_MAPSERVER_BASE=https://pkk.rosreestr.ru/arcgis/rest/services/PKK6/CadastreObjects/MapServer
# CADASTRE_PARCEL_LAYER_ID=21
# Если Node не может проверить сертификат НСПД/ПКК, задайте 1 (только для отладки).
# CADASTRE_TLS_INSECURE=1
# TIMEWEB_PROXY_SOURCE=
# Порт API (по умолчанию 3001)
PORT=3001

# PostgreSQL (обязательно для публикации объектов)
# Пример для Docker Compose:
# DATABASE_URL=postgresql://moinoviichistiimir:moinoviichistiimir_secret@db:5432/moinoviichistiimir
# Пример для локального PostgreSQL:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/moinoviichistiimir
# Если вы используете managed Postgres с обязательным SSL, задайте:
# PGSSLMODE=require
# DATABASE_URL=

# VirusTotal API v3 — проверка загружаемых PDF на вирусы (по желанию). Ключ: https://www.virustotal.com/gui/my-apikey
# VIRUSTOTAL_API_KEY=

# Яндекс Геокодер (для точного определения координат по юр. адресу в РФ)
# Создайте ключ в "JavaScript API и HTTP Геокодер" и вставьте сюда:
# YANDEX_GEOCODER_API_KEY=

# Telegram уведомления для чата поддержки:
# 1) Создайте бота через @BotFather и вставьте токен.
# 2) Напишите боту /start с вашего админ-аккаунта Telegram.
# 3) Если хотите явно задать чат — заполните TELEGRAM_ADMIN_CHAT_ID (иначе сервер попробует взять chat_id из getUpdates).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ADMIN_CHAT_ID=
