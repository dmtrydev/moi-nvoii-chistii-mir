# Timeweb Cloud AI — Access ID агента (обязателен для анализа лицензий)
# Документация: https://agent.timeweb.cloud/docs
TIMEWEB_ACCESS_ID=adea83eb-75b9-41cb-95e0-6cb244587767
# Bearer-токен (JWT API key из личного кабинета Timeweb). Если не задан, в Authorization используется Access ID.
# TIMEWEB_BEARER_TOKEN=eyJ...
# При необходимости укажите значение для заголовка x-proxy-source (если требуется API)
# TIMEWEB_PROXY_SOURCE=
# Порт API (по умолчанию 3001)
PORT=3001
# VirusTotal API v3 — проверка загружаемых PDF на вирусы (по желанию). Ключ: https://www.virustotal.com/gui/my-apikey
# VIRUSTOTAL_API_KEY=
