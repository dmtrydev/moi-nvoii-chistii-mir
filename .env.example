# URL API для загрузки/анализа лицензий (для dev: сначала запустите server: cd server && npm start)
# Без этой переменной запросы идут на тот же хост (работает только при npm run dev + прокси на :3001)
VITE_API_URL=http://localhost:3001

# Feature flags or app config (optional)
# VITE_APP_NAME=GreenX

# Кадастровая карта — внешний iframe-источник.
# Маркеры лицензий на iframe не рисуются — переключайтесь на «Обычная», чтобы видеть точки.
# VITE_CADASTRE_IFRAME_URL=https://ik10map.roscadastres.com/map.html?v=91

# ----------------------------------------------------------------------------
# Серверные переменные ниже задаются в server/.env (не в корневом .env).
# Перечислены здесь для справки.
# ----------------------------------------------------------------------------
# Bearer-токен для cron-синхронизации с реестром Росприроднадзора (см. RPN_SYNC.md).
# Используется только сервисным скриптом на VDS. Если переменная не задана,
# эндпойнты /api/rpn-sync/* возвращают 503 — это безопасный дефолт.
# Сгенерируйте: openssl rand -hex 32
# RPN_SYNC_TOKEN=
